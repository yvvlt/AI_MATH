      "선형변환 결과 점 (1,2): [ 4 -1]\n",
      "\n",
      "고유값: [ 1. -2.]\n",
      "고유벡터: [[ 0.89442719 -0.70710678]\n",
      " [ 0.4472136   0.70710678]]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "A = np.array([[0,2],\n",
    "              [1,-1]])\n",
    "\n",
    "v = np.array([1,2])\n",
    "\n",
    "transformed_v = A.dot(v)\n",
    "\n",
    "eigenvalues, eigenvectors = np.linalg.eig(A)\n",
    "\n",
    "print(\"선형변환 결과 점 (1,2):\", transformed_v)\n",
    "print(\"\\n고유값:\", eigenvalues)\n",
    "print(\"고유벡터:\", eigenvectors)"
   ]
  }
 ],
