     "text": [
      "행렬 A:\n",
      "[[1 3]\n",
      " [3 1]]\n",
      "\n",
      "고윳값 (Eigenvalues):\n",
      "[ 4. -2.]\n",
      "\n",
      "고유벡터 (Eigenvactors):\n",
      "[[ 0.70710678 -0.70710678]\n",
      " [ 0.70710678  0.70710678]]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "#행렬 입력\n",
    "A = np.array([[1,3],[3,1]])\n",
    "\n",
    "#고윳값과 고유벡터 계산\n",
    "eigenvalues, eigenvectors = np.linalg.eig(A)\n",
    "\n",
    "#결과 출력\n",
    "print(\"행렬 A:\")\n",
    "print(A)\n",
    "\n",
    "print(\"\\n고윳값 (Eigenvalues):\")\n",
    "print(eigenvalues)\n",
    "\n",
    "print(\"\\n고유벡터 (Eigenvactors):\")\n",
    "print(eigenvectors)"
   ]
  },
